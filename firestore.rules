rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Contenido público: proveedores y configuración del inicio.
    // Cualquiera puede LEER. Solo el administrador (con sesión) puede ESCRIBIR.
    match /content/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Solicitudes "Forma parte del equipo":
    // Cualquiera puede ENVIAR (create). Solo el administrador puede VER/BORRAR.
    match /equipo/{doc} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }
  }
}
